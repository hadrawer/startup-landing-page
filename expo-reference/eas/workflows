und\":\"default\",\"metrics\":[{\"icon\":{\"iconColor\":\"default\",\"iconName\":\"TerminalSquareSolidIcon\"},\"label\":\"of React Native devs use Expo\",\"value\":\"81%\"},{\"icon\":{\"iconColor\":\"blue\",\"iconName\":\"Tool01Icon\"},\"label\":\"React Native devs use Expo Application Services \",\"value\":\"70%\"},{\"icon\":{\"iconColor\":\"yellow\",\"iconName\":\"Star01SolidIcon\"},\"label\":\"GitHub Stars\",\"value\":\"40k+\"},{\"icon\":{\"iconColor\":\"green\",\"iconName\":\"ArrowCircleUpSolidIcon\"},\"label\":\"uptime SLA\",\"value\":\"99.9%\"}],\"paddingBottom\":\"regular\",\"paddingTop\":\"regular\",\"variant\":\"boxed\"},{\"_type\":\"landingPageTitle\",\"background\":\"default\",\"dividerTop\":false,\"link\":null,\"paddingBottom\":\"regular\",\"paddingTop\":\"regular\",\"subtitle\":\"You don't need to rip out your CI. Most teams start by offloading mobile builds to Expo Workflows, then expand over time. \",\"textAlign\":\"center\",\"title\":\"Integrate then scale\"},{\"_type\":\"landingPageRiver\",\"background\":\"default\",\"dividerBottom\":false,\"items\":[{\"description\":\"GitHub Actions handles everything: lint, tests, builds, signing, submissions. You manage macOS runners, Fastlane Match, keystore secrets, and ~100 lines of YAML per platform.\\n\\n✕ Paying for macOS runners ($0.08/min)\\n✕ Managing 10+ signing secrets\\n✕ Maintaining Fastlane Match repo\\n✕ Full rebuild on every push (~18 min)\",\"heading\":\"Your current GitHub Actions setup\",\"image\":{\"id\":\"image-c32043a26e751a4938ced92f27cd531e3f22f55a-2528x2528-png\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/c32043a26e751a4938ced92f27cd531e3f22f55a-2528x2528.png\"},\"link\":null,\"tag\":{\"color\":\"default\",\"label\":null},\"variant\":\"image-first\"},{\"description\":\"Keep GitHub Actions for lint, tests, and web builds. Offload mobile builds, submissions, and OTA to Workflows with a single CLI call.\\n\\n✓ No macOS runners needed in GHA\\n✓ One secret (EXPO_TOKEN) replaces all signing config\\n✓ Mobile builds run on M4 Pro, faster + cheaper\\n✓ Lint \u0026 tests stay exactly where they are\",\"heading\":\"Step 1: Add Workflows alongside GitHub Actions\",\"image\":{\"id\":\"image-6a2330df90347f9e5854edaf66dae05f355a3f15-2528x2528-png\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/6a2330df90347f9e5854edaf66dae05f355a3f15-2528x2528.png\"},\"link\":\"https://expo.dev/blog/how-to-integrate-eas-workflows-with-github-actions\",\"tag\":{\"color\":\"default\",\"label\":null},\"variant\":\"image-first\"},{\"description\":\"Move everything to Workflows. Trigger directly from GitHub events, Fingerprint detects what changed and runs only the jobs that matter\\n\\n✓ Zero GitHub Actions needed\\n✓ Typically, 40–60% of pushes skip full builds\\n✓ End-to-end in ~15 lines of YAML\\n✓ Managed hardware, signing, and caching\",\"heading\":\"Step 2: Full pipeline in Expo Workflows\",\"image\":{\"id\":\"image-08ed3ce5c7faa4fe3ca0502b2ac1d194caf42b09-2528x2528-png\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/08ed3ce5c7faa4fe3ca0502b2ac1d194caf42b09-2528x2528.png\"},\"link\":\"https://docs.expo.dev/eas/workflows/get-started/\",\"tag\":{\"color\":\"default\",\"label\":null},\"variant\":\"image-first\"}],\"paddingBottom\":\"regular\",\"paddingTop\":\"regular\",\"variant\":\"accordion\",\"verticalGap\":\"regular\"},{\"_type\":\"landingPageTitle\",\"background\":\"default\",\"dividerTop\":false,\"link\":null,\"paddingBottom\":\"regular\",\"paddingTop\":\"condensed\",\"subtitle\":null,\"textAlign\":\"center\",\"title\":\"Purpose-built infrastructure\"},{\"_type\":\"landingPageLinkGrid\",\"background\":\"default\",\"itemSize\":\"third\",\"links\":[{\"description\":\"Build, Submit, Update, Maestro, Repack, Fingerprint, Slack - composable. Full pipeline in ~6 lines. No bash scripts or Fastlane.\",\"hasBorder\":true,\"icon\":{\"iconColor\":\"default\",\"iconName\":\"ArrowCircleRightIcon\"},\"image\":{\"id\":null,\"url\":null},\"title\":\"Pre-packaged mobile jobs\",\"url\":null},{\"description\":\"iOS builds on dedicated M4 Pro hardware optimized for React Native. 10-20 min vs. 15-40 min on generic macOS VMs.\",\"hasBorder\":true,\"icon\":{\"iconColor\":\"default\",\"iconName\":\"CpuChip01Icon\"},\"image\":{\"id\":null,\"url\":null},\"title\":\"M4 Pro Apple Silicon\",\"url\":null},{\"description\":\"One EXPO_TOKEN replaces keystone base64 vars, Fastlane Match, and Apple API keys Encrypted at rest, injected at build time.\",\"hasBorder\":true,\"icon\":{\"iconColor\":\"default\",\"iconName\":\"Lock01Icon\"},\"image\":{\"id\":null,\"url\":null},\"title\":\"Managed signing\",\"url\":null},{\"description\":\"Slack notifications, artifact lookups, and lightweight tasks run instantly. Zero CI minutes consumed. No cold boot. \",\"hasBorder\":true,\"icon\":{\"iconColor\":\"default\",\"iconName\":\"Speedometer03Icon\"},\"image\":{\"id\":null,\"url\":null},\"title\":\"Instant jobs: ~300ms\",\"url\":null},{\"description\":\"Builds get faster as you use them. Hardware upgrades, cache tuning, and runtime optimizations applied automatically. \",\"hasBorder\":true,\"icon\":{\"iconColor\":\"default\",\"iconName\":\"CubeOutlineIcon\"},\"image\":{\"id\":null,\"url\":null},\"title\":\"Automatic caching\",\"url\":null},{\"description\":\"Trigger from GitHub events, invoke from any CI with eas workflow:run, or kick off manually from your terminal.\",\"hasBorder\":true,\"icon\":{\"iconColor\":\"default\",\"iconName\":\"GitMergeIcon\"},\"image\":{\"id\":null,\"url\":null},\"title\":\"Run from anywhere\",\"url\":null}],\"paddingBottom\":\"regular\",\"paddingTop\":\"regular\"},{\"_type\":\"landingPageRiver\",\"background\":\"default\",\"dividerBottom\":false,\"items\":[{\"description\":\"The invoice is just beginning. The real cost is invisible. Operational overhead, productivity loss, and deployment lag have an impact. Expo can reduce these DevOps costs by 80%, allowing engineers to focus on building features rather than managing infrastructure. \",\"heading\":\"The real cost of CI\",\"image\":{\"id\":\"image-65402e11b64d4583473b1975013318f0ce449495-2528x2528-jpg\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/65402e11b64d4583473b1975013318f0ce449495-2528x2528.jpg\"},\"link\":null,\"tag\":{\"color\":\"yellow\",\"label\":\"DevOps Tax\"},\"variant\":\"text-first\"},{\"description\":\"Expo Workflows serve as a high-performance mobile extension for GitHub Actions. While GitHub Actions is the standard CI for linting and tests, Expo eliminates the \\\"Engineering Tax\\\" of manual DevOps by automating iOS/Android build setups and code signing.\",\"heading\":\"Expo and GitHub Actions\",\"image\":{\"id\":\"image-72decd663dfac0b90bb400b2902a854ae6f39fb8-2528x2528-png\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/72decd663dfac0b90bb400b2902a854ae6f39fb8-2528x2528.png\"},\"link\":\"https://expo.dev/blog/how-to-integrate-eas-workflows-with-github-actions\",\"tag\":{\"color\":\"blue\",\"label\":\"Efficient\"},\"variant\":\"image-first\"}],\"paddingBottom\":\"regular\",\"paddingTop\":\"regular\",\"variant\":\"default\",\"verticalGap\":\"regular\"},{\"_type\":\"landingPageTitle\",\"background\":\"default\",\"dividerTop\":false,\"link\":null,\"paddingBottom\":\"regular\",\"paddingTop\":\"regular\",\"subtitle\":\"Choose the right path based on what changed in your CI/CD. Expo workflows provide the flexibility you need in one platform. \",\"textAlign\":\"center\",\"title\":\"Deployment speeds\"},{\"_type\":\"landingPageLinkGrid\",\"background\":\"default\",\"itemSize\":\"third\",\"links\":[{\"description\":\"Native code changed? Workflows runs a full compile, sign, and submit — on M4 Pro hardware. \",\"hasBorder\":true,\"icon\":{\"iconColor\":\"default\",\"iconName\":\"Cube01Icon\"},\"image\":{\"id\":null,\"url\":null},\"title\":\"Full Build: 10-20 min\",\"url\":\"https://docs.expo.dev/build/introduction/\"},{\"description\":\"No native changes detected. Workflows reuses yo