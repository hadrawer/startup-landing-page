anity.io/images/9r24npb8/production/c66cfa5b44bcc66682543358b45630f20c27ce7e-400x400.webp\"}],\"background\":null,\"eyebrow\":null,\"logos\":null,\"mode\":\"appIcons\",\"paddingBottom\":\"condensed\",\"paddingTop\":\"condensed\",\"theme\":\"adaptive\"},{\"_type\":\"landingPageTitle\",\"background\":\"default\",\"dividerTop\":true,\"link\":null,\"paddingBottom\":\"regular\",\"paddingTop\":\"spacious\",\"subtitle\":\"Every day spent on infrastructure is a day not validating product-market fit. Expo eliminates the technical barriers between your vision and your users, so you can focus on building a business, not maintaining build pipelines.\",\"textAlign\":\"center\",\"title\":\"Why startups bet on Expo\"},{\"_type\":\"landingPageRiver\",\"background\":\"default\",\"dividerBottom\":false,\"items\":[{\"description\":\"Your React team can ship native apps today. No expensive specialized hires, no platform silos, no multi-month delays. Expo serves all platforms with native performance. Deploy to the stores with the team you already have.\",\"heading\":\"Launch your app without hiring iOS/Android devs\",\"image\":{\"id\":\"image-6da6fb9c7a871992997e0b67414b66a66301db2b-1896x1896-png\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/6da6fb9c7a871992997e0b67414b66a66301db2b-1896x1896.png\"},\"link\":null,\"tag\":{\"color\":\"default\",\"label\":null},\"variant\":\"text-first\"},{\"description\":\"Push instant updates with EAS Update. No more 5-day review cycles killing your momentum. Fix bugs, ship features, run A/B tests all over-the-air. When every day counts, waiting for app store approval isn't an option. Ship fixes in minutes, not weeks.\",\"heading\":\"Fix critical bugs instantly\",\"image\":{\"id\":\"image-ba629ceab4f46732a8438a0cf3ad240148cb1c73-1896x1896-png\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/ba629ceab4f46732a8438a0cf3ad240148cb1c73-1896x1896.png\"},\"link\":null,\"tag\":{\"color\":\"default\",\"label\":null},\"variant\":\"text-first\"},{\"description\":\"Built on Cloudflare's edge network with SOC 2 compliance and 99.9% uptime SLA, the same codebase that powers your MVP will handle your Series B traffic. No painful migrations, no technical debt, no \\\"we need to rebuild everything\\\" conversations with investors.\",\"heading\":\"Scale from 10 users to 10 million without rewrites\",\"image\":{\"id\":\"image-3d25df2714e76d415644fe4aaa17ea6647faebe8-1896x1896-png\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/3d25df2714e76d415644fe4aaa17ea6647faebe8-1896x1896.png\"},\"link\":null,\"tag\":{\"color\":\"default\",\"label\":null},\"variant\":\"text-first\"},{\"description\":\"Cut infrastructure costs, DevOps overhead, and platform-specific teams. The Expo Free plan gets you to launch and our pricing scales with your business from there. Spend on growth, not on maintaining CI/CD pipelines. Every dollar saved extends your runway.\",\"heading\":\"Reduce burn rate on mobile development\",\"image\":{\"id\":\"image-c37dc122638b7618b15c94ab88a70a9dd5e723e4-1896x1896-png\",\"url\":\"https://cdn.sanity.io/images/9r24npb8/production/c37dc122638b7618b15c94ab88a70a9dd5e723e4-1896x1896.png\"},\"link\":null,\"tag\":{\"color\":\"default\",\"label\":null},\"variant\":\"text-first\"}],\"paddingBottom\":\"condensed\",\"paddingTop\":\"condensed\",\"variant\":\"default\",\"verticalGap\":\"regular\"},{\"_type\":\"landingPageKeyMetrics\",\"background\":\"default\",\"metrics\":[{\"icon\":{\"iconColor\":\"default\",\"iconName\":\"TerminalSquareSolidIcon\"},\"label\":\"React Native devs use the Expo CLI\",\"value\":\"81%\"},{\"icon\":{\"iconColor\":\"blue\",\"iconName\":\"Tool01Icon\"},\"label\":\"React Native devs use Expo Application Services\",\"value\":\"70%\"},{\"icon\":{\"iconColor\":\"yellow\",\"iconName\":\"Star01SolidIcon\"},\"label\":\"GitHub Stars\",\"value\":\"43k+\"},{\"icon\":{\"iconColor\":\"green\",\"iconName\":\"ArrowCircleUpSolidIcon\"},\"label\":\"Uptime SLA\",\"value\":\"99.9%\"}],\"pa